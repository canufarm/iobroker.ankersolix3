{
  "type": "tabs",
  "items": {
    "tab_account": {
      "type": "tab",
      "label": "Anker-Konto",
      "items": {
        "ankerUser": {
          "type": "text",
          "label": "Anker E-Mail",
          "sm": 12,
          "md": 6,
          "validator": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$",
          "validatorErrorText": "Bitte eine gültige E-Mail-Adresse eingeben"
        },
        "ankerPass": {
          "type": "password",
          "label": "Anker Passwort",
          "sm": 12,
          "md": 6
        },
        "ankerCountry": {
          "type": "text",
          "label": "Ländercode (z.B. DE)",
          "sm": 6,
          "md": 3
        },
        "ankerServer": {
          "type": "text",
          "label": "API-Server (EU-Standard beibehalten)",
          "sm": 12,
          "md": 9
        }
      }
    },
    "tab_device": {
      "type": "tab",
      "label": "Gerät",
      "items": {
        "deviceSns": {
          "type": "text",
          "label": "Seriennummern des Geräts",
          "sm": 12,
          "md": 8,
          "help": "z.B. APCDJQD0F19200721"
        },
        "devicePn": {
          "type": "text",
          "label": "Produktcode (Product Number)",
          "sm": 6,
          "md": 4,
          "help": "z.B. A17C5 für Solarbank 3 E2700"
        }
      }
    },
    "tab_behavior": {
      "type": "tab",
      "label": "Schlaf & Nachtruhe",
      "items": {
        "_headerIdle": {
          "type": "header",
          "text": "Automatischer Schlafmodus (kein Solar/Batterie)"
        },
        "idleThresholdW": {
          "type": "number",
          "label": "Schwellenwert Solar (Watt)",
          "sm": 6,
          "md": 4,
          "help": "Unter diesem Wert gilt das Gerät als inaktiv"
        },
        "idleTimeoutS": {
          "type": "number",
          "label": "Wartezeit bis Trigger-Stop (Sekunden)",
          "sm": 6,
          "md": 4,
          "help": "Wie lange muss Solar = 0 sein, bevor der Trigger pausiert wird"
        },
        "staleTimeoutS": {
          "type": "number",
          "label": "Timeout ohne Daten (Sekunden)",
          "sm": 6,
          "md": 4,
          "help": "Wie lange ohne eingehende Daten, bis Trigger pausiert wird"
        },
        "_headerNight": {
          "type": "header",
          "text": "Nachtruhe-Fenster (feste Abschaltzeit)"
        },
        "_nightHelp": {
          "type": "staticText",
          "text": "Format: 4 Ziffern (HHMM), z.B. 2200 und 0700. Wenn Start leer bleibt, ist die Nachtruhe deaktiviert.",
          "style": { "color": "gray", "fontSize": "0.85em" }
        },
        "nightSleepStart": {
          "type": "text",
          "label": "Nachtruhe Beginn (HHMM)",
          "sm": 6,
          "md": 3,
          "help": "z.B. 2200 – leer = kein Nachtschlaf"
        },
        "nightSleepEnd": {
          "type": "text",
          "label": "Nachtruhe Ende (HHMM)",
          "sm": 6,
          "md": 3,
          "help": "z.B. 0700"
        }
      }
    }
  }
}
